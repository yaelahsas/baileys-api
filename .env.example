# Api host and port
HOST=127.0.0.1
PORT=9999

# Number retry to connect to whatsapp -1 for infinite
MAX_RETRIES=-1

# Reconnect interval in milliseconds (base delay, exponential backoff will be applied)
RECONNECT_INTERVAL=5000

# Keep-alive interval in milliseconds (sends presence update to keep connection alive)
KEEP_ALIVE_INTERVAL=25000

# Connection check interval in milliseconds (monitors connection health)
CONNECTION_CHECK_INTERVAL=60000

# Authentication
AUTHENTICATION_GLOBAL_AUTH_TOKEN=A4gx18YGxKAvR01ClcHpcR7TjZUNtwvE

# WEBHOOK CONFIGURATION
# Set to 'false' to disable all webhook sending
APP_WEBHOOK_ENABLED=false
APP_WEBHOOK_URL="https://webhook.site/dbf387ed-a861-4ae9-9b30-9344c972cb74"
APP_WEBHOOK_ALLOWED_EVENTS=MESSAGES_UPSERT,MESSAGES_DELETE,MESSAGES_UPDATE
APP_WEBHOOK_FILE_IN_BASE64=false

# AUTO READ MESSAGES
# Set to 'true' to automatically mark incoming messages as read
AUTO_READ_MESSAGES=true

# API CONFIGURATION
# Base URL for the external API
API_BASE_URL=http://sim-mtsn.test/api
# API key for authentication
API_KEY=whatsapp_bot_key_2024
# Request timeout in milliseconds (30 seconds)
API_TIMEOUT=30000
# Maximum retry attempts for API requests
API_MAX_RETRIES=3
# Delay between retries in milliseconds
API_RETRY_DELAY=2000
